# PLAB — copy to `.env` and adjust (never commit `.env`).
# cp .env.example .env

# --- Django core ---
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
# Comma-separated hostnames, e.g. plab.example.com,www.plab.example.com
ALLOWED_HOSTS=127.0.0.1,localhost

# HTTPS (production). Set to False only if TLS is terminated elsewhere and you know the risks.
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
# Comma-separated origins: https://plab.example.com,https://www.plab.example.com
CSRF_TRUSTED_ORIGINS=

# Optional: HSTS (seconds). Use 0 to disable.
SECURE_HSTS_SECONDS=31536000

# --- Paths (relative to project root = folder containing manage.py) ---
STATIC_ROOT_DIR=staticfiles
MEDIA_ROOT_DIR=media

# --- Optional SQLite path (absolute or relative to BASE_DIR) ---
# SQLITE_PATH=db.sqlite3

# --- About page & lab branding (optional; empty = use defaults in settings or placeholders in templates) ---
PLAB_ABOUT_DESCRIPTION=
PLAB_ABOUT_DESCRIPTION_AR=
PLAB_ABOUT_PHONE=
PLAB_ABOUT_ADDRESS=
PLAB_ABOUT_ADDRESS_AR=
PLAB_ABOUT_HOURS=
PLAB_ABOUT_HOURS_AR=
# Google Maps embed iframe src URL only
PLAB_MAP_EMBED_URL=
